# ═══════════════════════════════════════════════════════
#  Agentic RAG SaaS — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── LLM (NVIDIA API) ────────────────────────────────────
NVIDIA_API_KEY=YOUR_NVEDIA_API_KEY
LLM_MODEL=qwen/qwen3-235b-a22b

# ── Embeddings ───────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5   # Free local model via fastembed
# EMBED_MODEL=text-embedding-3-small  # OpenAI (paid, better quality)

# ── Qdrant (Vector DB) ───────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_docs

# ── Backend ──────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# ── Chunking ─────────────────────────────────────────────
CHUNK_SIZE=600
CHUNK_OVERLAP=100
TOP_K=6

# ── Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Redis Cache ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600

# ── MongoDB ──────────────────────────────────────────────
MONGODB_URL=mongodb://mongodb:27017/rag_saas

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
