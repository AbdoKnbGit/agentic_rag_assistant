{
  "title": "Agentic RAG — Monitoring",
  "uid": "rag-dashboard",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Requêtes RAG (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "rag_queries_total", "legendFormat": "Requêtes" }]
    },
    {
      "id": 2,
      "title": "Documents ingérés (total)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "documents_ingested_total", "legendFormat": "Documents" }]
    },
    {
      "id": 3,
      "title": "Latence HTTP (p95)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }]
    },
    {
      "id": 4,
      "title": "Requêtes HTTP par endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [{
        "expr": "rate(http_requests_total[1m])",
        "legendFormat": "{{method}} {{endpoint}} {{status}}"
      }]
    }
  ]
}
